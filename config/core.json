{
  "discord": {
    "token": "",
    "clientId": "",
    "ownerIds": [],
    "intents": [
      "Guilds",
      "GuildMessages",
      "GuildMembers",
      "GuildVoiceStates",
      "MessageContent"
    ],
    "partials": []
  },
  "bot": {
    "prefix": "!",
    "activity": {
      "name": "modular plugins",
      "type": "Watching",
      "status": "online"
    },
    "defaultCooldownMs": 2500
  },
  "commands": {
    "slashRegistration": "guild",
    "guildIds": [],
    "registerOnReady": false,
    "allowPrefixCommands": true,
    "allowDashboardTesting": true
  },
  "plugins": {
    "directory": "plugins",
    "configDirectory": "config/plugins",
    "dataDirectory": "data/plugins",
    "autoLoad": true,
    "installDependencies": true,
    "dependencyInstall": {
      "ignoreScripts": true,
      "omitDev": true,
      "timeoutMs": 120000
    }
  },
  "dashboard": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 3000,
    "publicUrl": "http://localhost:3000",
    "sessionSecret": "",
    "adminUserIds": [],
    "allowAnyAuthenticatedUser": false,
    "rateLimit": {
      "windowMs": 60000,
      "max": 120
    }
  },
  "logging": {
    "level": "info",
    "console": true,
    "file": true,
    "filePath": "logs/bot.log",
    "maxMemoryEntries": 500
  },
  "security": {
    "allowRemotePluginInstall": true,
    "allowUntrustedPluginInstall": false,
    "enforcePluginPermissions": true,
    "allowedPluginHosts": [
      "github.com",
      "raw.githubusercontent.com",
      "codeload.github.com"
    ],
    "maxPluginArchiveBytes": 52428800
  }
}
