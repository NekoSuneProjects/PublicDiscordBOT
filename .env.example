# Required Discord credentials
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: comma-separated Discord user IDs
DISCORD_OWNER_IDS=

# Optional command behavior overrides
BOT_PREFIX=!
COMMANDS_SLASH_REGISTRATION=guild
COMMANDS_GUILD_IDS=
COMMANDS_REGISTER_ON_READY=false
COMMANDS_ALLOW_PREFIX=true
COMMANDS_ALLOW_DASHBOARD_TESTING=true

# Dashboard / OAuth
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000
DASHBOARD_PUBLIC_URL=http://localhost:3000
DASHBOARD_SESSION_SECRET=
DASHBOARD_ADMIN_USER_IDS=
DASHBOARD_ALLOW_ANY_AUTH_USER=false
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Logging
LOG_LEVEL=info
LOG_CONSOLE=true
LOG_FILE=true
LOG_FILE_PATH=logs/bot.log

# Optional integrations
GITHUB_TOKEN=
