{
  "name": "utility-example",
  "version": "1.0.0",
  "description": "Example utility plugin with auto-moderation, XP leveling, storage, and config management.",
  "main": "index.js",
  "dependencies": {
    "fs-extra": "^11.3.5"
  },
  "modularDiscordBotPlugin": {
    "id": "utility-example",
    "name": "Utility Example",
    "version": "1.0.0",
    "entry": "index.js",
    "defaultEnabled": true,
    "permissions": [
      "discord.commands",
      "discord.events.messageCreate",
      "dashboard.components",
      "storage"
    ]
  }
}
