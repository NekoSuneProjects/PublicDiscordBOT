{
  "name": "music-example",
  "version": "1.0.0",
  "description": "Example music plugin using @discordjs/voice and play-dl for YouTube and Spotify lookup.",
  "main": "index.js",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "ffmpeg-static": "^5.3.0",
    "play-dl": "^1.9.7"
  },
  "modularDiscordBotPlugin": {
    "id": "music-example",
    "name": "Music Example",
    "version": "1.0.0",
    "entry": "index.js",
    "defaultEnabled": false,
    "permissions": [
      "discord.commands",
      "voice",
      "network"
    ]
  }
}
